# API Keys - Get these for FREE:
# Apollo: https://apollo.io (Free: 75 credits/month)
# Hunter: https://hunter.io (Free: 50 credits/month)
# Brevo: https://brevo.com (Free: 300 emails/day)
# ZeroBounce: https://zerobounce.net (Free: 100 verifications/month)

APOLLO_API_KEY=your_apollo_api_key_here
HUNTER_API_KEY=your_hunter_api_key_here
BREVO_API_KEY=your_brevo_api_key_here
ZEROBOUNCE_API_KEY=your_zerobounce_api_key_here

# OpenAI/mimo-v2.5
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://llm2.jugaar.ai/v1
OPENAI_MODEL=xiaomimimo/mimo-v2.5

# Database
DATABASE_URL=postgresql+asyncpg://leadgen:leadgen123@localhost:5432/leadgen

# Email Settings - Update with your domain
EMAIL_FROM=your-name@yourdomain.com
EMAIL_FROM_NAME=Your Name
EMAIL_REPLY_TO=your-reply@yourdomain.com

# Domain
DOMAIN=yourdomain.com

# Limits
MAX_EMAILS_PER_DAY=300

# Logging
LOG_LEVEL=INFO